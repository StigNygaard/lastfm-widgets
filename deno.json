{
    "exclude": ["cf-worker/"],
    "tasks": {
        "dev": "deno --watch --unstable-kv --allow-net --allow-env --allow-read=./website,./widgets,./services,./.env main.ts",
        "start": "deno --unstable-kv --allow-net --allow-env --allow-read=./website,./widgets,./services,./.env main.ts",
        "lint": "deno lint main.ts services/"
    },
    "deploy": {
        "exclude": [
            "**/node_modules"
        ],
        "include": []
    },
    "imports": {
        "@kitsonk/kv-toolbox": "jsr:@kitsonk/kv-toolbox@^0.31.0",
        "@std/dotenv": "jsr:@std/dotenv@^0.225.7",
        "@std/http": "jsr:@std/http@^1.1.2"
    }
}
